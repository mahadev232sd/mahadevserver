PORT=5000
# One line, no spaces around = . Replace USER, PASSWORD, cluster host, and db name.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/mahadev?retryWrites=true&w=majority
# Optional alias (some platforms set this instead):
# DATABASE_URL=mongodb+srv://...
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
ALLOWED_ORIGINS=
ALLOW_DEV_OTP=false
ADMIN_EMAIL=admin@mahadev.local
ADMIN_PASSWORD=Admin123!
